---
title: ""
layout: "layouts/home.njk"
permalink: "/"
---

<!-- Banner -->
<section id="banner">
  <div class="container">
    <div class="logo"><img src="{{ site.path.prefix }}{{ site.path.assets }}{{ banner.logo.imgSrc }}" alt="{{ banner.logo.imgAlt }}"></div>
    <header>
      <h2>{{ banner.header.title }}</h2>
      {% for paragraph in banner.header.text %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </header>
  </div>
</section>

<!-- Intro -->
<section id="intro" class="wrapper style1">
  <div class="container">
    <h2>
      {{ intro.header.title }}<br/>
      <span>{{ intro.header.subtitle }}</span>
    </h2>
    <footer>
      {% for paragraph in intro.header.text %}
      <p>{{ paragraph }}</p>
      {% endfor %}
      <ul class="actions">
        <li><a href="#" class="button primary large">Saiba mais</a></li>
      </ul>
    </footer>
  </div>
</section>

<!-- Main -->
<section id="main" class="wrapper style2">
  <div class="container">
      <!-- Core competences -->
      <section id="competences">
        <header>
          <h2 class="centered">{{ competences.header.title }}</h2>
          {% for paragraph in competences.header.text %}
          <p>{{ paragraph }}</p>
          {% endfor %}
        </header>
        <div class="row">
          {% for item in competences.articles %}
          <div class="col-6 col-12-mobile bottom-gutter">
            <section>
              <header>
                <div class="image fit">
                  <img src="{{ site.path.prefix }}{{ site.path.assets }}{{ item.imgSrc }}" alt="{{ item.imgAlt }}">
                </div>
                <div class="illustrated-title">
                  <img src="{{ site.path.prefix }}{{ site.path.assets }}{{ item.icon }}" alt="Ícone abstrato.">
                  <h3>{{ item.title }}</h3>
                </div>
              </header>
                {% for paragraph in item.text %}
                  <p>{{ paragraph }}</p>
                {% endfor %}
            </section>
          </div>
          {% endfor %}
        </div>
      </section>

      <!-- Harpia -->
      <section id="harpia">
        <div class="row">
          <div class="col-4 col-12-narrow">
            <header>
              <h2>{{ harpia.header.title }}</h2>
            </header>
            {% for paragraph in harpia.text %}
            <p>{{ paragraph }}</p>
            {% endfor %}
          </div>
          <div class="col-8 col-12-narrow">
            <div class="image fit">
              <img src="{{ site.path.prefix }}{{ site.path.assets }}{{ harpia.imgSrc }}" alt="{{ harpia.imgAlt }}">
            </div>
            <ul class="icon-bullets">
              {% for bullet in harpia.kpis %}
                <li class="icon condensed solid fa-cog">{{ bullet.text | safe }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </section>

